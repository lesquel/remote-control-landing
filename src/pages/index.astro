---
import Base             from '~/layouts/Base.astro';
import Nav              from '~/components/Nav.astro';
import Hero             from '~/components/Hero.astro';
import Problem          from '~/components/Problem.astro';
import MultiCli         from '~/components/MultiCli.astro';
import Features         from '~/components/Features.astro';
import DashboardMockup  from '~/components/DashboardMockup.astro';
import Architecture     from '~/components/Architecture.astro';
import Install          from '~/components/Install.astro';
import UseCases         from '~/components/UseCases.astro';
import Mobile           from '~/components/Mobile.astro';
import Shortcuts        from '~/components/Shortcuts.astro';
import Config           from '~/components/Config.astro';
import Roadmap          from '~/components/Roadmap.astro';
import Docs             from '~/components/Docs.astro';
import Footer           from '~/components/Footer.astro';
import TweaksPanel      from '~/components/TweaksPanel.astro';

const lang = 'en';
---

<Base lang={lang}>
  <Nav lang={lang} />
  <Hero lang={lang} />
  <Problem lang={lang} />
  <MultiCli lang={lang} />
  <Features lang={lang} />
  <DashboardMockup lang={lang} />
  <Architecture lang={lang} />
  <Install lang={lang} />
  <UseCases lang={lang} />
  <Mobile lang={lang} />
  <Shortcuts lang={lang} />
  <Config lang={lang} />
  <Roadmap lang={lang} />
  <Docs lang={lang} />
  <Footer lang={lang} />
  <TweaksPanel lang={lang} />
</Base>
