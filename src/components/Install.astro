---
import { STRINGS, type Lang } from '~/i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = STRINGS[lang].install;
---

<section class="block" id="install" data-screen-label="install">
  <div class="wrap">
    <div class="eyebrow" data-animate>{t.eyebrow}</div>
    <h2 class="section-title" data-animate data-delay="1">{t.title}</h2>
    <p class="section-sub" data-animate data-delay="2">{t.sub}</p>

    <div class="steps">
      {t.steps.map((s, i) => (
        <div class="step" data-animate data-delay={String(i + 1)} data-tilt>
          <h4>{s.title}</h4>
          <p>{s.body}</p>
          {s.extra && <div class="prereq-line">{s.extra}</div>}
          {s.cmd && (
            <div class="cmd">
              <span class="ps">{s.prompt}</span><span>{s.cmd}</span>
              <button class="cp" type="button" data-copy={s.cmd}>copy</button>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="extra-box" data-animate>
      <div class="box-label">{t.uninstallLabel}</div>
      <div class="box-body">
        <div class="cmd">
          <span class="ps">$</span><span>{t.uninstallCmd}</span>
          <button class="cp" type="button" data-copy={t.uninstallCmd}>copy</button>
        </div>
        <div class="hint">{t.uninstallHint}</div>
        <div class="cmd hint-mt">
          <span class="ps">$</span><span>{t.uninstallKeepCmd}</span>
          <button class="cp" type="button" data-copy={t.uninstallKeepCmd}>copy</button>
        </div>
        <div class="hint">{t.uninstallKeepHint}</div>
      </div>
    </div>

    <div class="extra-box mt" data-animate>
      <div class="box-label">{t.doctorLabel}</div>
      <div class="cmd">
        <span class="ps">$</span><span>{t.doctorCmd}</span>
        <button class="cp" type="button" data-copy={t.doctorCmd}>copy</button>
      </div>
      <div class="hint top">{t.doctorHint}</div>
    </div>
  </div>
</section>

<style>
  .prereq-line { color: var(--fg-dim); margin-top: 12px; font-size: 12px; }
  .extra-box {
    margin-top: 40px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }
  .extra-box.mt { margin-top: 24px; }
  .box-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-dim);
    margin-bottom: 16px;
  }
  .box-body { display: grid; gap: 12px; }
  .hint { font-size: 12px; color: var(--fg-dim); }
  .hint.top { margin-top: 12px; }
  .hint-mt { margin-top: 12px; }
</style>
