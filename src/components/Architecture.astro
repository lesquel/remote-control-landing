---
import { STRINGS, type Lang } from '~/i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = STRINGS[lang].architecture;
---

<section class="block" id="arch" data-screen-label="arch">
  <div class="wrap">
    <div class="eyebrow" data-animate>{t.eyebrow}</div>
    <h2 class="section-title" data-animate data-delay="1">{t.title}</h2>
    <p class="section-sub" data-animate data-delay="2">{t.sub}</p>

    <div class="diagram" data-animate data-delay="3">
<pre>{`┌─────────────────────┐      ┌─────────────────────────┐
│   OpenCode TUI      │      │   Codex CLI (hooks)     │
│   (SDK plugin)      │      │   POST /codex/hooks/*   │
└──────────┬──────────┘      └──────────┬──────────────┘
           │                            │
           ▼                            ▼
   ┌──────────────────────────────────────────┐
   │  integrations/  ports.ts                 │
   │  ├── opencode/  (native SDK)             │
   │  └── codex/     (HTTP bridge)            │
   └─────────────────┬────────────────────────┘
                     │
   ┌─────────────────▼────────────────────────┐
   │  core/                                   │  ← domain
   │  permissions · events · audit · settings │
   └─────────────────┬────────────────────────┘
                     │
   ┌─────────────────▼────────────────────────┐
   │  transport/http   ←→   notifications/    │
   │  Bun.serve + SSE       Telegram + Push   │
   └─────────────────┬────────────────────────┘
                     │
   ┌─────────────────▼────────────────────────┐
   │  dashboard/  (vanilla SPA, same origin)  │
   └──────────────────────────────────────────┘`}</pre>
    </div>

    <div class="layers-grid">
      {t.layers.map((l, i) => (
        <div class="arch-step" data-tilt data-animate data-delay={String((i % 4) + 1)}>
          <div class="layer-head">
            <h4>{l.name}</h4>
            <span class="layer-tag">{l.tag}</span>
          </div>
          <p>{l.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .diagram {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 28px;
    margin-top: 12px;
    overflow-x: auto;
  }
  .diagram pre {
    margin: 0;
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--fg-muted);
    font-family: var(--mono);
  }
  .layers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    margin-top: 32px;
  }
  .layer-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 8px;
  }
  .layer-head h4 { margin: 0; color: var(--accent); font-family: var(--mono); font-size: 14px; }
  .layer-tag {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-dim);
    border: 1px solid var(--line-2);
    padding: 1px 6px;
    border-radius: 99px;
  }
</style>
