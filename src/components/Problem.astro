---
import { STRINGS, type Lang } from '~/i18n/strings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = STRINGS[lang].problem;
---

<section class="block" id="problem" data-screen-label="problem">
  <div class="wrap">
    <div class="eyebrow" data-animate>{t.eyebrow}</div>
    <h2 class="section-title" data-animate data-delay="1">{t.title}</h2>
    <p class="section-sub" data-animate data-delay="2">{t.sub}</p>

    <div class="pain-grid">
      {t.pains.map((p, i) => (
        <div class="pain-card" data-tilt data-animate data-delay={String((i % 4) + 1)}>
          <div class="pain-ico">{p.icon}</div>
          <h4>{p.title}</h4>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 40px;
  }
  .pain-ico { font-size: 18px; margin-bottom: 8px; }
</style>
